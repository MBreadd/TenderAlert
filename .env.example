# Copia este archivo a .env.local y rellena los valores. NUNCA subas .env.local.

# --- IA (Persona C) — Claude API server-side ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Datos oficiales SUNAT/OSCE vía Latinfo (Persona B) ---
LATINFO_API_URL=https://api.latinfo.example/v1
LATINFO_API_KEY=

# --- Base de datos Supabase (Persona B) ---
# La URL puede ser pública; la service role key es SECRETA (solo server-side).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
